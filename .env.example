# Required security environment variables for backend startup
APP_SECURITY_ADMIN_USERNAME=admin
APP_SECURITY_ADMIN_PASSWORD=change-me-admin
APP_SECURITY_CUSTOMER_USERNAME=customer@example.com
APP_SECURITY_CUSTOMER_PASSWORD=change-me-customer
# Use at least 32 characters
APP_SECURITY_JWT_SECRET=replace-with-a-strong-32-char-minimum-secret
APP_SECURITY_JWT_TTL_SECONDS=900

# Optional hardening controls
APP_SECURITY_RATE_LIMIT_LOGIN_PER_MINUTE=10
APP_SECURITY_RATE_LIMIT_WRITE_PER_MINUTE=120
APP_SECURITY_LOGIN_MAX_FAILURES=5
APP_SECURITY_LOGIN_FAILURE_WINDOW_SECONDS=300
APP_SECURITY_LOGIN_BLOCK_DURATION_SECONDS=600
